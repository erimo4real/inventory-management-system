{
  "name": "inventory-management-backend",
  "version": "1.0.0",
  "description": "Node.js backend for inventory management system",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node --dns-result-order=ipv4first src/server.js",
