PORT=3000
JWT_SECRET=change-me-to-a-random-secret

# ---------------------------------------------------------------
# Database — pick one:
# ---------------------------------------------------------------

# Option A: Supabase (production)
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxxxx.supabase.co:5432/postgres

# Option B: Local PostgreSQL (development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=inventory_db
DB_USER=postgres
DB_PASSWORD=postgres
# DB_SSL=true    # enable for cloud-hosted Postgres

# CORS — comma-separated origins allowed (localhost auto-allowed in code)
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost,https://your-app.netlify.app

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP (password-reset emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FRONTEND_URL=http://localhost:5173
